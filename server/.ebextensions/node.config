option_settings:
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
    PORT: 8080

container_commands:
  01_remove_node_modules:
    command: "sudo rm -rf /var/app/staging/node_modules"
  02_npm_install:
    command: "sudo npm install --omit=dev"
    cwd: "/var/app/staging"
  03_prisma_generate:
    command: "sudo npx prisma generate"
    cwd: "/var/app/staging"